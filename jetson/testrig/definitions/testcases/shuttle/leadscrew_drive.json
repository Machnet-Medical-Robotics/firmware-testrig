{
  "schema_version": "1.0",
  "test_case_id": "TC-SH-LEADSCREW-DRIVE",
  "metadata": {
    "test_name": "Shuttle Leadscrew Drive",
    "description": "Validates the leadscrew drive by running on-demand BIST then moving to setpoint and back.",
    "tags": ["leadscrew", "stepper", "shuttle"],
    "estimated_duration_ms": 30000
  },
  "config": {
    "echo_console": true
  },
  "steps": [
    {
      "step_id": 1,
      "type": "console",
      "device": "monitoring_pcb",
      "description": "Enter service mode",
      "command": "com_enter_service_mode",
      "return_string_match": "cmd OK",
      "timeout_ms": 5000,
      "stop_if_fail": true
    },
    {
      "step_id": 2,
      "type": "console",
      "device": "monitoring_pcb",
      "description": "Run on-demand BIST on shuttle leadscrew",
      "command": "on_demand_leadscrew",
      "return_string_match": "BIST SUCCESS",
      "timeout_ms": 15000,
      "stop_if_fail": true
    },
    {
      "step_id": 3,
      "type": "console",
      "device": "monitoring_pcb",
      "description": "Move leadscrew to 100mm at 350mm/s",
      "command": "com_leadscrew_go",
      "command_param": "100 350",
      "return_string_match": "cmd OK",
      "timeout_ms": 5000,
      "stop_if_fail": true
    },
    {
      "step_id": 4,
      "type": "channel_wait",
      "device": "monitoring_pcb",
      "description": "Wait until leadscrew reaches 100mm setpoint",
      "channel_name": "stepper1_controller",
      "expected": {
        "channel_offset": 0,
        "min": 99.9,
        "max": 100.1
      },
      "timeout_ms": 15000,
      "stop_if_fail": true
    },
    {
      "step_id": 5,
      "type": "console",
      "device": "monitoring_pcb",
      "description": "Move leadscrew back to 0mm at 350mm/s",
      "command": "com_leadscrew_go",
      "command_param": "0 350",
      "return_string_match": "cmd OK",
      "timeout_ms": 5000,
      "stop_if_fail": true
    },
    {
      "step_id": 6,
      "type": "channel_wait",
      "device": "monitoring_pcb",
      "description": "Wait until leadscrew returns to 0mm",
      "channel_name": "stepper1_controller",
      "expected": {
        "channel_offset": 0,
        "min": -0.1,
        "max": 0.1
      },
      "timeout_ms": 15000,
      "stop_if_fail": true
    }
  ],
  "on_fail": [
    {
      "command": "com_change_mode",
      "command_param": "2"
    }
  ]
}
